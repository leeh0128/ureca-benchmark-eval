#!/usr/bin/env python3
#=========================================================================
# sv-generate-agentic [options] prompt-filename
#=========================================================================
#
# Drop-in agentic replacement for VerilogEval v2's `sv-generate`.
#
# Instead of a single LLM call, this runs a feedback loop:
#   generate -> compile+simulate with iverilog -> on failure, feed the
#   error back to the model -> regenerate -> repeat up to --max-iters.
#
# It is CLI-compatible with the stock sv-generate for the flags the
# VerilogEval Makefile passes (--model --examples --rules --task
# --temperature --top-p --output --verbose), so it can be dropped in
# by pointing GENERATE_VERILOG at this script.
#
# Free-tier focus:
#   - Targets Gemini via the OpenAI-compatible endpoint.
#   - Rate-limit aware (configurable RPM, automatic backoff on 429).
#   - Logs token usage for EVERY call to a per-sample JSON sidecar so
#     total cost for paid models (e.g. Sonnet 4.6) can be extrapolated.
#
#  -v --verbose       Display prompts and responses
#  -h --help          Display this message
#  -m --model         LLM model (default: gemini-2.0-flash)
#  -t --temperature   LLM temperature (default: 0.0)
#  -p --top-p         LLM top_p (default: 0.01)
#  -n --max-tokens    LLM max_tokens per call (default: 2048)
#  -x --examples      In-context examples, 0-4 (default: 0)
#  -r --rules         Include in-context coding rules
#     --task          Task: spec-to-rtl | code-complete-iccad2023
#     --output        File to write extracted code
#     --max-iters     Max feedback-loop iterations (default: 5)
#     --rpm           Max requests per minute, rate limiting (default: 12)
#     --tokenlog      Token-usage JSON sidecar path (default: <output>.tokens.json)
#
#=========================================================================

import argparse
import json
import os
import re
import subprocess
import sys
import time
from collections import namedtuple

#-------------------------------------------------------------------------
# Command line
#-------------------------------------------------------------------------

class ArgParser(argparse.ArgumentParser):
    def error(self, msg=""):
        if msg:
            print(f"\n ERROR: {msg}\n")
        sys.exit(2)


def parse_cmdline():
    p = ArgParser(add_help=False)
    p.add_argument("-h", "--help",        action="store_true")
    p.add_argument("-v", "--verbose",     action="store_true")
    p.add_argument("-m", "--model",       type=str,   default="gemini-2.0-flash")
    p.add_argument("-t", "--temperature", type=float, default=0.0)
    p.add_argument("-n", "--max-tokens",  type=int,   default=2048)
    p.add_argument("-p", "--top-p",       type=float, default=0.01)
    p.add_argument("-e", "--explain",     action="store_true")
    p.add_argument("-x", "--examples",    type=int,   default=0)
    p.add_argument("-r", "--rules",       action="store_true")
    p.add_argument("--task",        type=str, default="spec-to-rtl")
    p.add_argument("--output",      type=str, default="-")
    p.add_argument("--max-iters",   type=int, default=5)
    p.add_argument("--rpm",         type=int, default=12)
    p.add_argument("--tokenlog",    type=str, default=None)
    p.add_argument("--ureca-dir",   type=str, default="",
                   help="Path to ureca_designs/ with Makefile + scripts/. "
                        "When set, every iteration runs the URECA pipeline "
                        "(make lint + make report) for structured feedback "
                        "alongside the iverilog functional test.")
    p.add_argument("prompt_filename")
    opts = p.parse_args()
    if opts.help:
        print(__doc__ or "see header")
        sys.exit(0)
    return opts


